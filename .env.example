# Vercel KV (content/site.json store)
# Pull these from the Vercel dashboard: Storage → your KV store → ".env.local" tab
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Admin auth (HTTP Basic on /admin, /api/content, /api/upload)
# Defaults to user=naman, pass=studio if unset — change before production!
ADMIN_USER=naman
ADMIN_PASSWORD=change-me

# Vercel Blob (uploaded images/videos)
# Pull from: Storage → your Blob store → ".env.local" tab
BLOB_READ_WRITE_TOKEN=
